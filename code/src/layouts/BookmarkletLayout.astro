---
import PrimaryNav from '../components/PrimaryNav.astro'
import '/node_modules/rivet-core/css/rivet.min.css'
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<title>LibGuides Accessibility Tool</title>
        <meta name="title" content="LibGuides Accessibility Tool">
        <meta name="description" content="Discover known accessibility violations on LibGuides pages and correct them">
        <meta name="keywords" content="accessibility, libguides, IU, indiana university, libraries">
        <meta name="robots" content="noindex, nofollow">
        <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
        <meta name="language" content="English">
        <style>
            main {
                width: 400px;
                position: absolute;
                top: 0;
                right: 0;
                z-index: 2000000000;
            }
        </style>
	</head>
	<body>
        <main data-drag data-snapped>
            <PrimaryNav data-drag-source></PrimaryNav>
		    <slot></slot>
        </main>
        <script type="module" lang="js">
            // // @ts-expect-error no type definitions for rivet-core
            // import Rivet from 'rivet-core'  
            // Rivet.init()

            // Drag
            const draggableElement = document.querySelector('[data-drag]');
            const dragSourceElement = document.querySelector('[data-drag-source]');
            const minimiseBtn = document.querySelector('[data-minimise]');
            const snapToSideBtn = document.querySelector('[data-snap]');
            const closeBtn = document.querySelector('[data-close]');

            snapToSideBtn.addEventListener('click', () => {
                const draggableElement = document.querySelector('[data-drag]');
                draggableElement.style.left = 'unset';
                draggableElement.style.top = '0px';
                draggableElement.style.right = '0px';
                draggableElement.setAttribute('data-snapped','');
            })

            window.addEventListener('resize', function () {
                const rect = draggableElement.getBoundingClientRect();

                if (draggableElement.hasAttribute('data-snapped')) return;

                const currentX = parseFloat(draggableElement.style.left) || 0;
                const currentY = parseFloat(draggableElement.style.top) || 0;

                // Clamp to new window bounds
                const clampedX = Math.max(0, Math.min(currentX, window.innerWidth - rect.width));
                const clampedY = Math.max(0, Math.min(currentY, window.innerHeight - rect.height));

                draggableElement.style.left = `${clampedX}px`;
                draggableElement.style.top = `${clampedY}px`;
            });

            let offsetX = 0, offsetY = 0;
            dragSourceElement.addEventListener('mousedown', function (e) {
                // Preventing default behavior to avoid unwanted selections
                e.preventDefault();

                // Calculating initial offsets
                offsetX = e.clientX - draggableElement.getBoundingClientRect().left;
                offsetY = e.clientY - draggableElement.getBoundingClientRect().top;

                // Adding the 'dragging' class to apply styling changes
                draggableElement.classList.add('dragging');
                draggableElement.removeAttribute('data-snapped');

                // Adding event listeners for mousemove and mouseup
                document.addEventListener('mousemove', dragElement);
                document.addEventListener('mouseup', stopDragging);
            });

            function dragElement(e) {
                const rect = draggableElement.getBoundingClientRect();

                // Calculate new position
                let newX = e.clientX - offsetX;
                let newY = e.clientY - offsetY;

                // Clamp to window bounds
                newX = Math.max(0, Math.min(newX, window.innerWidth - rect.width));
                newY = Math.max(0, Math.min(newY, window.innerHeight - rect.height));

                draggableElement.style.left = `${newX}px`;
                draggableElement.style.top = `${newY}px`;
            }

            function stopDragging(e) {
                // Preventing default behavior to avoid unwanted selections
                e.preventDefault();

                // Removing the 'dragging' class to revert styling changes
                draggableElement.classList.remove('dragging');

                // Removing event listeners to stop tracking mouse movements
                document.removeEventListener('mousemove', dragElement);
                document.removeEventListener('mouseup', stopDragging);
            }
            
        </script>
	</body>
</html>