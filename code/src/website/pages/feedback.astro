---
import DocumentationLayout from "../layouts/DocumentationLayout.astro"
import PageLayout from "../layouts/PageLayout.astro"
import CONFIG from '../../bookmarklet/config.json' with { type: 'json' };
---

<PageLayout title="Feedback">

    <main id="main-content" class="rvt-layout__wrapper rvt-layout__wrapper--single rvt-container-sm">
        <div class="rvt-prose rvt-p-all-md rvt-flex rvt-flex-column rvt-align-center rvt-items-center">

                <h1 class="rvt-ts-32 rvt-text-center rvt-text-medium rvt-m-top-md">We'd Love your Feedback!</h1>
                <a class="rvt-button rvt-m-top-lg" href={CONFIG.feedback}>Share your Feedback</a>

        </div>
    </main>

</PageLayout>