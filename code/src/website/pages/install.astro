---
import PageLayout from "../layouts/PageLayout.astro"
import CONFIG from '../../bookmarklet/config.json' with { type: 'json' };
import bookmarkletContent from '../../../dist-bookmarklet/bookmarklet.txt?raw';
const BOOKMARKLET_URL_ENCODED = encodeURI(bookmarkletContent.trim());
---

<PageLayout title="Install">

    <main id="main-content" class="rvt-layout__wrapper rvt-layout__wrapper--single rvt-container-sm">
        <div class="rvt-layout__content">

            <div class="rvt-p-all-md">
                <h1 class="rvt-ts-32 rvt-text-center rvt-text-medium rvt-m-top-md">Install the {CONFIG.title}</h1>
                <p class="rvt-ts-18 rvt-text-center">Click-and-Drag the Bookmarklet below into your Bookmarks Bar</p>
                <!-- <p>Don't see a Bookmarks Bar? Press <kbd>Command/Ctrl</kbd> + <kbd>Shift</kbd> + <kbd>B</kbd></p> -->
                
                <a class="install-btn rvt-button rvt-button--secondary rvt-flex rvt-flex-column rvt-items-center rvt-justify-center rvt-p-all-md rvt-m-top-xl rvt-m-bottom-none rvt-text-center" href={BOOKMARKLET_URL_ENCODED}>
                    <img src="/favicon.svg" alt="">
                    <p>{CONFIG.title}</p>
                </a>

            </div>


            <div class="rvt-flex rvt-justify-center rvt-p-tb-xxl rvt-m-tb-lg rvt-flow rvt-prose rvt-bg-black-000 rvt-border-radius ">
                <div class="rvt-container-sm rvt-flex rvt-items-center rvt-p-lr-xxl">
                    <div class="rvt-p-left-xl-md-up rvt-flow rvt-prose">
                        <h2>Next Steps</h2>
                        <p>Visit </p>
                        <a class="rvt-cta" href="/docs">How to Use the Tool</a>
                    </div>
                </div>
            </div>
        </div>
    </main>

</PageLayout>


<style>
    .install-btn {
        width: max-content;
        height: max-content;
        justify-self: center;
    }
</style>

<script lang="js">
    document.querySelector('.install-btn').addEventListener('click', (e) => {
        e.preventDefault()
    })
</script>