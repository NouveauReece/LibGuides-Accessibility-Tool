---
import type { SidebarNode } from '../../../scripts/build-docs-sidebar';

interface Props {
  nodes: SidebarNode[];
  currentPath: string;
  isRoot?: boolean;
  toggleAttribute?: string;
  isOpen?: boolean;
}

const {
  nodes, currentPath,
  isRoot = true,
  toggleAttribute = null,
  isOpen = true
} = Astro.props;

function containsCurrentPath(node: SidebarNode, path: string): boolean {
  if (node.href === path) return true;
  return node.children.some((child) => containsCurrentPath(child, path));
}
---


<ul class="rvt-sidenav__list" data-rvt-sidenav-list={toggleAttribute || undefined} hidden={!isOpen}>
  {nodes.map((node) => {
    const isCurrent = node.href === currentPath;
    const isActiveBranch = containsCurrentPath(node, currentPath);
    const hasChildren = node.children.length > 0;

    return (
      <li class="rvt-sidenav__item">
        {hasChildren ? (
          <div class="rvt-sidenav__item-wrapper">
            <a
              href={node.href}
              class="rvt-sidenav__link"
              aria-current={isCurrent ? 'page' : undefined}
            >
              {node.tab || node.title}
            </a>
            <button
              class="rvt-sidenav__toggle"
              data-rvt-sidenav-toggle={node.href}
              aria-expanded={isActiveBranch ? 'true' : 'false'}
            >
              <span class="rvt-sr-only">Show more {node.title} links</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="m15.146 6.263-1.292-1.526L8 9.69 2.146 4.737.854 6.263 8 12.31l7.146-6.047Z"/>
              </svg>
            </button>
          </div>
        ) : (
          <a
            href={node.href}
            class="rvt-sidenav__link"
            aria-current={isCurrent ? 'page' : undefined}
          >
            {node.tab || node.title}
          </a>
        )}

        {hasChildren && (
          <Astro.self
            nodes={node.children}
            currentPath={currentPath}
            isRoot={false}
            toggleAttribute={node.href}
            isOpen={isActiveBranch}
          />
        )}
      </li>
    );
  })}
</ul>


<style>
.rvt-sidenav__item .rvt-sidenav__list {
  margin-left: 1rem;
  margin-top: .25rem;
  margin-bottom: .25rem;
}
</style>