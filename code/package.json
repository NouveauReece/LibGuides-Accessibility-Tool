{
  "name": "astro",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev:astro": "astro dev",
    "build:astro": "astro build",
    "dev:bookmarklet": "vite dev --config vite.bookmarklet.config.mjs",
    "build:bookmarklet": "vite build --config vite.bookmarklet.config.mjs && node scripts/wrap-bookmarklet.mjs",
    "build:bookmarklet:external-lit": "EXTERNAL_LIT=true vite build --config vite.bookmarklet.config.mjs && node scripts/wrap-bookmarklet.mjs",
    "build:bookmarklet:bundled-lit": "EXTERNAL_LIT=false vite build --config vite.bookmarklet.config.mjs && node scripts/wrap-bookmarklet.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "test": "echo hi"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/starlight": "^0.39.2",
    "astro": "^6.3.1",
    "dayjs": "^1.11.21",
    "lit": "^3.3.3",
    "rivet-core": "^2.9.1",
    "rivet-icons": "^3.0.1",
    "shiki": "^4.2.0"
  },
  "devDependencies": {
    "axe-core": "^4.11.4",
    "jsdom": "^29.1.1"
  }
}
